@model IEnumerable<FitTrack_Pro.ViewModels.PlanResponseViewModel>

@{
    ViewData["Title"] = "Plans";
}

<div class="container-fluid px-0">
    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <div>
            <h2 class="fw-bold mb-1">Subscription Plans</h2>
            <p class="text-muted mb-0">Manage available subscription plans for members.</p>
        </div>
        <div>
            <a asp-controller="Plans" asp-action="AddPlan" class="btn btn-primary rounded-pill px-4">
                <i class="fas fa-plus me-2"></i>Add Plan
            </a>
        </div>
    </div>

    <div class="row g-4" id="plansList">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4" data-plan-id="@item.Id">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="fw-bold mb-1">@item.Name</h5>
                                <span class="text-muted" style="font-size:0.9rem">@item.DurationInDays days</span>
                            </div>

                            <p class="text-muted mb-3">@item.Description</p>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div>
                                    <h4 class="fw-bold mb-0 text-primary">@item.Price.ToString("C")</h4>
                                </div>

                                <div>
                                    <a asp-controller="Plans" asp-action="Update" asp-route-id="@item.Id"
                                        class="btn btn-outline-secondary rounded-pill me-2">Update</a>

                                    <form asp-controller="Plans" asp-action="Delete" asp-route-id="@item.Id" method="post"
                                        class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="btn btn-danger rounded-pill btn-delete"
                                            data-id="@item.Id" data-name="@item.Name">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center">
                    <div class="card-body">
                        <p class="text-muted mb-2">No plans found.</p>
                        <a asp-controller="Plans" asp-action="AddPlan" class="btn btn-primary rounded-pill px-4">
                            Create your first plan
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel"
    aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow-sm border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="confirmDeleteModalLabel">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0 text-muted" id="confirmDeleteMessage">Are you sure you want to delete this plan?</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger rounded-pill">Yes, Delete</button>
            </div>
        </div>
    </div>
</div>

<!-- Result Modal -->
<div class="modal fade" id="resultModal" tabindex="-1" aria-labelledby="resultModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow-sm border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="resultModalLabel">Result</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0" id="resultMessage"></p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-primary rounded-pill" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var deleteButtons = document.querySelectorAll('.btn-delete');
            var confirmModal = new bootstrap.Modal(document.getElementById('confirmDeleteModal'));
            var resultModal = new bootstrap.Modal(document.getElementById('resultModal'));
            var confirmMessage = document.getElementById('confirmDeleteMessage');
            var resultMessage = document.getElementById('resultMessage');
            var confirmDeleteBtn = document.getElementById('confirmDeleteBtn');

            var selectedForm = null;
            var selectedCard = null;

            deleteButtons.forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    selectedForm = btn.closest('form');
                    selectedCard = btn.closest('[data-plan-id]');
                    var planName = btn.getAttribute('data-name') || 'this plan';
                    confirmMessage.textContent = 'Are you sure you want to delete "' + planName + '"?';
                    confirmModal.show();
                });
            });

            confirmDeleteBtn.addEventListener('click', function () {
                if (!selectedForm) return;

                var action = selectedForm.getAttribute('action');
                var formData = new FormData(selectedForm);

                // Perform AJAX POST
                fetch(action, {
                    method: 'POST',
                    body: formData,
                    credentials: 'same-origin'
                })
                .then(function (response) {
                    confirmModal.hide();
                    if (response.ok) {
                        // Success
                        resultMessage.textContent = 'Plan deleted successfully.';
                        // remove the card from UI
                        if (selectedCard && selectedCard.parentNode) {
                            selectedCard.parentNode.removeChild(selectedCard);
                        }
                    } else {
                        // Error
                        resultMessage.textContent = 'An error happened while deleting the plan.';
                    }
                    resultModal.show();
                })
                .catch(function (err) {
                    confirmModal.hide();
                    resultMessage.textContent = 'An error happened while deleting the plan.';
                    resultModal.show();
                });
            });
        });
    </script>
}

<style>
    .rounded-4 {
        border-radius: 1rem !important;
    }
</style>
